<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/art_screen_bg"
    tools:context=".ArtActivity">

    <androidx.cardview.widget.CardView
        android:id="@+id/artHeaderCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="20dp"
        app:cardBackgroundColor="#1F2438"
        app:cardCornerRadius="28dp"
        app:cardElevation="6dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/chip_bg_dark"
                android:paddingStart="10dp"
                android:paddingTop="4dp"
                android:paddingEnd="10dp"
                android:paddingBottom="4dp"
                android:text="@string/monthly_canvas"
                android:textColor="@color/sky"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/artTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@android:color/white"
                android:textSize="28sp"
                tools:text="April 2026" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/art_subtitle"
                android:textColor="#C6D0EB"
                android:textSize="14sp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/artPreviewCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="20dp"
        app:cardBackgroundColor="#FFF8F1"
        app:cardCornerRadius="32dp"
        app:cardElevation="10dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/artHeaderCard">

        <ImageView
            android:id="@+id/artPreview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/art_preview"
            android:padding="14dp"
            android:scaleType="fitCenter" />
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:id="@+id/artActions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="20dp"
        android:background="@drawable/art_actions_bg"
        android:padding="10dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/artPreviewCard">

        <ImageButton
            android:id="@+id/regenerateButton"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_margin="8dp"
            android:background="@drawable/round_button_bg_light"
            android:contentDescription="@string/regenerate_art"
            android:padding="16dp"
            android:src="@android:drawable/ic_popup_sync"
            android:tint="@color/ink" />

        <ImageButton
            android:id="@+id/saveButton"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_margin="8dp"
            android:background="@drawable/round_button_bg_light"
            android:contentDescription="@string/save_art"
            android:padding="16dp"
            android:src="@android:drawable/ic_menu_save"
            android:tint="@color/ink" />

        <ImageButton
            android:id="@+id/shareButton"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_margin="8dp"
            android:background="@drawable/round_button_bg_light"
            android:contentDescription="@string/share_art"
            android:padding="16dp"
            android:src="@android:drawable/ic_menu_share"
            android:tint="@color/ink" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
